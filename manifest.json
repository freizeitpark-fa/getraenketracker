<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0f766e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Getränke">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="manifest" href="manifest.json">
  <link rel="apple-touch-icon" href="icons/icon-192.png">
  <title>Kreuzfahrt Getränketracker</title>
  <style>
    :root{--bg:#f6f7f8;--card:#fff;--ink:#17202a;--muted:#697386;--brand:#0f766e;--danger:#b91c1c;--warn:#b45309;--ok:#047857;--line:#e5e7eb;--shadow:0 10px 28px rgba(15,23,42,.08)}
    *{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;padding-bottom:92px} header{position:sticky;top:0;z-index:10;background:rgba(246,247,248,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:calc(env(safe-area-inset-top) + 10px) 16px 10px} h1{font-size:20px;margin:0 0 4px} .sub{color:var(--muted);font-size:13px}.wrap{padding:14px;max-width:860px;margin:0 auto}.card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:14px;margin:12px 0;box-shadow:var(--shadow)}.row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.btn{border:0;border-radius:14px;background:var(--brand);color:white;padding:12px 14px;font-weight:700;font-size:15px;min-height:46px}.btn.secondary{background:#e6f3f1;color:#0f514b}.btn.ghost{background:#eef0f2;color:#273142}.btn.danger{background:#fee2e2;color:var(--danger)}input,select,textarea{width:100%;border:1px solid var(--line);border-radius:14px;background:#fff;padding:12px;font-size:16px}label{display:block;font-weight:700;font-size:13px;margin:10px 0 6px}.person,.drink{padding:13px;border:1px solid var(--line);border-radius:16px;background:#fff;text-align:left}.person.active{outline:3px solid #99d8d0}.drink small,.muted{color:var(--muted)}.pill{display:inline-block;padding:3px 8px;border-radius:999px;font-size:12px;font-weight:700}.ok{background:#dcfce7;color:var(--ok)}.no{background:#fee2e2;color:var(--danger)}.unclear{background:#fef3c7;color:var(--warn)}nav{position:fixed;left:0;right:0;bottom:0;z-index:20;background:rgba(255,255,255,.95);backdrop-filter:blur(14px);border-top:1px solid var(--line);padding:8px 8px calc(env(safe-area-inset-bottom) + 8px);display:grid;grid-template-columns:repeat(4,1fr);gap:6px}nav button{border:0;background:transparent;border-radius:12px;padding:9px 3px;font-size:12px;color:#334155}nav button.active{background:#e6f3f1;color:#0f514b;font-weight:800}.hide{display:none!important}.kpi{background:#f8fafc;border:1px solid var(--line);border-radius:16px;padding:12px}.kpi b{display:block;font-size:22px;margin-top:4px}.list{display:flex;flex-direction:column;gap:8px}.item{display:flex;justify-content:space-between;gap:10px;border-bottom:1px solid var(--line);padding:10px 0}.item:last-child{border-bottom:0}.small{font-size:12px}.setup{min-height:100vh}.warnbox{border-left:4px solid var(--warn);background:#fffbeb;padding:10px;border-radius:12px;color:#78350f}.successbox{border-left:4px solid var(--ok);background:#ecfdf5;padding:10px;border-radius:12px;color:#064e3b}@media(min-width:700px){.grid{grid-template-columns:repeat(3,1fr)}nav{max-width:860px;left:50%;transform:translateX(-50%);border:1px solid var(--line);border-radius:22px 22px 0 0}}
  </style>
</head>
<body>
<header><h1>Getränketracker</h1><div class="sub" id="statusLine">Offline bereit</div></header>
<main class="wrap">
  <section id="setup" class="setup hide">
    <div class="card"><h2>Ersteinrichtung</h2><p class="muted">Daten bleiben ausschließlich lokal auf diesem Gerät.</p>
      <label>Gerätename</label><input id="deviceName" placeholder="z. B. Fabians iPhone">
      <div id="setupPersons"></div><button class="btn secondary" id="addSetupPerson">Person hinzufügen</button>
      <button class="btn" id="finishSetup" style="width:100%;margin-top:14px">Einrichtung speichern</button>
    </div>
  </section>
  <section id="track" class="screen"><div class="card"><h2>Schnellerfassung</h2><div class="grid" id="personButtons"></div><label>Getränk suchen</label><input id="search" placeholder="Name oder Kategorie"><div class="list" id="drinkList"></div></div></section>
  <section id="stats" class="screen hide"><div class="card"><h2>Auswertung</h2><div class="grid3" id="kpis"></div></div><div class="card"><h3>Personen</h3><div id="personStats" class="list"></div></div><div class="card"><h3>Letzte Buchungen</h3><div id="entries" class="list"></div></div></section>
  <section id="data" class="screen hide"><div class="card"><h2>Daten</h2><button class="btn secondary" id="exportBtn">Backup exportieren</button><label>Backup importieren</label><input type="file" id="importBackup" accept="application/json"><div id="backupMsg"></div></div>
    <div class="card"><h2>Barkarte aktualisieren</h2><p class="warnbox">PDFs werden in dieser Offline-Version nicht automatisch ausgelesen. Lade stattdessen eine JSON-/CSV-Datei oder füge extrahierten Text ein. Die App vergleicht danach neue Artikel und Preisänderungen.</p><label>Barkarte JSON/CSV importieren</label><input type="file" id="importMenu" accept=".json,.csv,text/csv,application/json"><label>Textimport</label><textarea id="menuText" rows="6" placeholder="Je Zeile: Getränk;Kategorie;Preis"></textarea><button class="btn" id="parseText">Text vergleichen/importieren</button><div id="compareResult"></div></div>
  </section>
  <section id="settings" class="screen hide"><div class="card"><h2>Einstellungen</h2><div id="peopleSettings"></div><button class="btn secondary" id="addPerson">Person hinzufügen</button><button class="btn danger" id="resetBtn" style="width:100%;margin-top:14px">App zurücksetzen</button></div></section>
</main>
<nav><button data-tab="track" class="active">Erfassen</button><button data-tab="stats">Auswertung</button><button data-tab="data">Daten</button><button data-tab="settings">Setup</button></nav>
<script>
const KEY='gt_pwa_v1'; let state={device:'',people:[],drinks:[],entries:[],selectedPerson:null,menuVersion:''};
const qs=s=>document.querySelector(s), qsa=s=>[...document.querySelectorAll(s)];
function uid(){return Math.random().toString(36).slice(2)+Date.now().toString(36)}
function eur(n){return (Number(n)||0).toLocaleString('de-DE',{style:'currency',currency:'EUR'})}
function save(){localStorage.setItem(KEY,JSON.stringify(state));renderAll()}
function load(){const raw=localStorage.getItem(KEY); if(raw){state=JSON.parse(raw);return true} return false}
async function initData(){try{const r=await fetch('./data/stamm-barkarte.json'); const d=await r.json(); state.drinks=d.drinks||[]; state.menuVersion=d.version||''}catch(e){state.drinks=[]}}
function statusFor(drink,person){if(!person||person.package==='none')return 'nicht_enthalten'; return (drink.packageStatus&&drink.packageStatus[person.package])||'unklar'}
function badge(st){return st==='enthalten'?'<span class="pill ok">enthalten</span>':st==='nicht_enthalten'?'<span class="pill no">nicht enthalten</span>':'<span class="pill unclear">unklar</span>'}
function showSetup(){qs('#setup').classList.remove('hide'); qsa('.screen,nav').forEach(e=>e.classList.add('hide')); setupPersonRow()}
function setupPersonRow(){const box=qs('#setupPersons'); if(!state.people.length) state.people=[{id:uid(),name:'',package:'comfort',packagePrice:0}]; box.innerHTML=state.people.map((p,i)=>personForm(p,i,'setup')).join('')}
function personForm(p,i,prefix){return `<div class="card" style="box-shadow:none"><label>Name</label><input data-person-field="name" data-i="${i}" value="${p.name||''}" placeholder="Person ${i+1}"><label>Paket</label><select data-person-field="package" data-i="${i}">${pkgOptions(p.package)}</select><label>Paketpreis gesamt</label><input data-person-field="packagePrice" data-i="${i}" type="number" step="0.01" value="${p.packagePrice||0}"></div>`}
function pkgOptions(v){return [['none','Kein Paket'],['kids','Kids / Teens Paket'],['light','Light Paket'],['comfort','Comfort Paket'],['comfort_deluxe','Comfort Deluxe Paket'],['premium','Premium / All Inclusive'],['unknown','Unklar']].map(x=>`<option value="${x[0]}" ${x[0]===v?'selected':''}>${x[1]}</option>`).join('')}
document.addEventListener('input',e=>{if(e.target.dataset.personField){const i=+e.target.dataset.i; const f=e.target.dataset.personField; state.people[i][f]=f==='packagePrice'?Number(e.target.value||0):e.target.value}});
qs('#addSetupPerson').onclick=()=>{state.people.push({id:uid(),name:'',package:'comfort',packagePrice:0});setupPersonRow()};
qs('#finishSetup').onclick=()=>{state.device=qs('#deviceName').value||'iPhone'; state.people=state.people.filter(p=>p.name.trim()); if(!state.people.length){alert('Bitte mindestens eine Person anlegen.');return} state.selectedPerson=state.people[0].id; save(); location.reload()};
function renderTrack(){qs('#statusLine').textContent=(navigator.onLine?'Online':'Offline')+' · '+(state.device||'Gerät')+' · '+state.drinks.length+' Getränke'; qs('#personButtons').innerHTML=state.people.map(p=>`<button class="person ${p.id===state.selectedPerson?'active':''}" data-person="${p.id}"><b>${p.name}</b><br><small>${p.package}</small></button>`).join(''); renderDrinks()}
function renderDrinks(){const term=(qs('#search').value||'').toLowerCase(); const p=state.people.find(x=>x.id===state.selectedPerson); const list=state.drinks.filter(d=>(d.name+' '+d.category).toLowerCase().includes(term)).slice(0,80); qs('#drinkList').innerHTML=list.map(d=>`<button class="drink" data-drink="${d.id}"><b>${d.name}</b><br><small>${d.category||''} · ${eur(d.price)} · ${badge(statusFor(d,p))}</small></button>`).join('')}
document.addEventListener('click',e=>{const pb=e.target.closest('[data-person]'); if(pb){state.selectedPerson=pb.dataset.person; save()} const db=e.target.closest('[data-drink]'); if(db){addEntry(db.dataset.drink)} const tab=e.target.closest('nav button'); if(tab) switchTab(tab.dataset.tab)});
qs('#search').oninput=renderDrinks;
function addEntry(drinkId){const p=state.people.find(x=>x.id===state.selectedPerson), d=state.drinks.find(x=>x.id===drinkId); if(!p||!d)return; state.entries.unshift({id:uid(),ts:new Date().toISOString(),personId:p.id,drinkId:d.id,name:d.name,category:d.category,price:Number(d.price)||0,status:statusFor(d,p)}); save()}
function switchTab(id){qsa('.screen').forEach(s=>s.classList.toggle('hide',s.id!==id)); qsa('nav button').forEach(b=>b.classList.toggle('active',b.dataset.tab===id)); if(id==='stats')renderStats(); if(id==='settings')renderSettings()}
function renderStats(){const total=state.entries.reduce((a,e)=>a+e.price,0), included=state.entries.filter(e=>e.status==='enthalten').reduce((a,e)=>a+e.price,0), notInc=state.entries.filter(e=>e.status!=='enthalten').reduce((a,e)=>a+e.price,0), pkg=state.people.reduce((a,p)=>a+(Number(p.packagePrice)||0),0); qs('#kpis').innerHTML=[['Barkartenwert',total],['im Paket',included],['nicht/unklar',notInc],['Paketpreis',pkg],['Saldo',included-pkg],['Buchungen',state.entries.length,'']].map(k=>`<div class="kpi"><span>${k[0]}</span><b>${k[2]===''?k[1]:eur(k[1])}</b></div>`).join(''); qs('#personStats').innerHTML=state.people.map(p=>{const es=state.entries.filter(e=>e.personId===p.id), sum=es.reduce((a,e)=>a+e.price,0), inc=es.filter(e=>e.status==='enthalten').reduce((a,e)=>a+e.price,0); return `<div class="item"><div><b>${p.name}</b><br><span class="small muted">${es.length} Getränke · Paketpreis ${eur(p.packagePrice)}</span></div><div><b>${eur(sum)}</b><br><span class="small">Paketwert ${eur(inc)}</span></div></div>`}).join(''); qs('#entries').innerHTML=state.entries.slice(0,25).map(e=>`<div class="item"><div><b>${e.name}</b><br><span class="small muted">${new Date(e.ts).toLocaleString('de-DE')} · ${state.people.find(p=>p.id===e.personId)?.name||''} · ${badge(e.status)}</span></div><b>${eur(e.price)}</b></div>`).join('')}
function renderSettings(){qs('#peopleSettings').innerHTML=state.people.map((p,i)=>personForm(p,i,'settings')).join('')}
qs('#addPerson').onclick=()=>{state.people.push({id:uid(),name:'Neue Person',package:'comfort',packagePrice:0});save();renderSettings()};
qs('#resetBtn').onclick=()=>{if(confirm('Alle lokalen Daten löschen?')){localStorage.removeItem(KEY);location.reload()}};
qs('#exportBtn').onclick=()=>{const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='Getraenketracker_Backup_'+new Date().toISOString().slice(0,10)+'.json'; a.click()};
qs('#importBackup').onchange=async e=>{const f=e.target.files[0]; if(!f)return; state=JSON.parse(await f.text()); save(); qs('#backupMsg').innerHTML='<p class="successbox">Backup importiert.</p>'};
function normalizeDrink(x){const name=(x.name||x.Name||x.getraenk||x['Getränk']||'').trim(); const price=Number(String(x.price||x.Preis||x.preis||'0').replace(',','.').replace(/[^0-9.]/g,'')); return name?{id:name.toLowerCase().replace(/[^a-z0-9äöüß]+/gi,'_'),name,category:x.category||x.Kategorie||'Import',price,packageStatus:{unknown:'unklar'}}:null}
function compareImport(newDrinks){const old=Object.fromEntries(state.drinks.map(d=>[d.name.toLowerCase(),d])); let added=0,changed=0; newDrinks.forEach(d=>{const o=old[d.name.toLowerCase()]; if(!o){state.drinks.push(d);added++} else if(Number(o.price)!==Number(d.price)){o.oldPrice=o.price;o.price=d.price;changed++}}); save(); qs('#compareResult').innerHTML=`<p class="successbox">Import verarbeitet: ${added} neue Getränke, ${changed} Preisänderungen.</p>`}
qs('#importMenu').onchange=async e=>{const f=e.target.files[0]; if(!f)return; const txt=await f.text(); let arr=[]; if(f.name.endsWith('.json')) arr=(JSON.parse(txt).drinks||JSON.parse(txt)); else arr=txt.split(/\r?\n/).map(l=>{const [name,category,price]=l.split(';');return {name,category,price}}); compareImport(arr.map(normalizeDrink).filter(Boolean))};
qs('#parseText').onclick=()=>{const arr=qs('#menuText').value.split(/\r?\n/).map(l=>{const [name,category,price]=l.split(';');return {name,category,price}}).map(normalizeDrink).filter(Boolean); compareImport(arr)};
function renderAll(){if(!state.people.length)return; renderTrack(); if(!qs('#stats').classList.contains('hide'))renderStats(); if(!qs('#settings').classList.contains('hide'))renderSettings()}
(async()=>{if(!load()){await initData();showSetup()}else{renderAll()} if('serviceWorker' in navigator) navigator.serviceWorker.register('./sw.js')})();
</script>
</body>
</html>
